{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "db/*": ["db/*"]
    }
  },
  "include": ["netlify/functions/**/*.mts", "db/**/*.ts", "drizzle.config.ts"],
  "exclude": ["node_modules"]
}
